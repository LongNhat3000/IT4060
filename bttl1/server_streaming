#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <sys/socket.h>
#include <netinet/in.h>
#include <unistd.h>

#define TARGET "0123456789"
#define PORT 9999

int main() {
    int s = socket(AF_INET, SOCK_STREAM, 0);
    struct sockaddr_in addr = {AF_INET, htons(PORT), INADDR_ANY};
    
    bind(s, (struct sockaddr*)&addr, sizeof(addr));
    listen(s, 5);
    printf("Server 1.2 dang cho du lieu tai port %d...\n", PORT);

    int c = accept(s, NULL, NULL);
    char buf[1024];
    char residual[10] = ""; // Luu 9 ky tu cuoi cua lan nhan truoc
    int count = 0;

    while (1) {
        int n = recv(c, buf, sizeof(buf) - 1, 0);
        if (n <= 0) break;
        buf[n] = '\0';

        // Tao buffer tam de ghep phan du cu voi du lieu moi
        char temp[2048];
        sprintf(temp, "%s%s", residual, buf);

        // Tim kiem chuoi muc tieu
        char *ptr = temp;
        while ((ptr = strstr(ptr, TARGET)) != NULL) {
            count++;
            ptr += 1; 
        }

        // Cap nhat phan du (9 ky tu cuoi cung)
        int len = strlen(temp);
        if (len >= 9) {
            strcpy(residual, temp + len - 9);
        } else {
            strcpy(residual, temp);
        }

        printf("Nhan duoc: %s | Tong so chuoi '0123456789': %d\n", buf, count);
    }

    close(c); close(s);
    return 0;
}
