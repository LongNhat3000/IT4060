#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <unistd.h>
#include <sys/socket.h>
#include <netinet/in.h>

#define PORT 8888

// Hàm đọc từng byte cho đến khi gặp ký tự kết thúc chuỗi \0
int read_string(int sock, char *buffer) {
    int i = 0;
    while (read(sock, &buffer[i], 1) > 0) {
        if (buffer[i] == '\0') return i + 1; // Trả về số byte đã đọc
        i++;
    }
    return 0;
}

int main(int argc, char *argv[]) {
    int server_fd, new_socket;
    struct sockaddr_in address;
    int opt = 1;
    int addrlen = sizeof(address);

    server_fd = socket(AF_INET, SOCK_STREAM, 0);
    setsockopt(server_fd, SOL_SOCKET, SO_REUSEADDR, &opt, sizeof(opt));

    address.sin_family = AF_INET;
    address.sin_addr.s_addr = INADDR_ANY;
    address.sin_port = htons(PORT);

    if (bind(server_fd, (struct sockaddr *)&address, sizeof(address)) < 0) {
        perror("Bind failed");
        exit(EXIT_FAILURE);
    }
    listen(server_fd, 3);

    printf("Server 1.1 dang cho ket noi tai port %d...\n", PORT);
    new_socket = accept(server_fd, (struct sockaddr *)&address, (socklen_t*)&addrlen);

    // 1. Đọc tên thư mục đầu tiên
    char current_dir[256];
    if (read_string(new_socket, current_dir) > 0) {
        printf("--- THU MUC: %s ---\n", current_dir);
    }

    // 2. Vòng lặp đọc danh sách file: [Tên file]\0[Kích thước]
    char f_name[256];
    long f_size;

    while (read_string(new_socket, f_name) > 0) {
        // Sau khi đọc xong tên file, đọc tiếp 8 byte kích thước (long)
        if (read(new_socket, &f_size, sizeof(long)) > 0) {
            printf("+ %-20s | %ld bytes\n", f_name, f_size);
        } else {
            break;
        }
    }

    printf("-----------------------------------\n");
    printf("Da nhan xong du lieu.\n");

    close(new_socket);
    close(server_fd);
    return 0;
}
